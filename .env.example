# AptAdapt 环境变量配置
# 复制本文件为 .env，并填写你的真实密钥

# ── 讯飞开放平台（必填）──
# 从 https://xinghuo.xfyun.cn/ 获取
LLM_PROVIDER=xfyun
XFYUN_APPID=your_appid_here
XFYUN_API_KEY=your_api_key_here
XFYUN_API_SECRET=your_api_secret_here
XFYUN_CHAT_HOST=spark-api.xf-yun.com
XFYUN_CHAT_PATH=/v4.0/chat
XFYUN_CHAT_DOMAIN=4.0Ultra

# ── 大模型运行策略 ──
# 超时时间越小失败越快；如果网络慢可调大。当前建议 8-15 秒。
LLM_TIMEOUT_SECONDS=10
# 某次调用失败后，短时间内直接快速失败，避免一个流程连续卡在坏接口上。
LLM_FAILURE_COOLDOWN_SECONDS=45
# 降低温度可让教学输出更稳定。
LLM_TEMPERATURE=0.35
# 限制输出长度可提升响应速度，资源生成需要更长时再调大。
LLM_MAX_TOKENS=1200
SUPERVISOR_USE_LLM=0
REVIEWER_USE_LLM=0

# ── 讯飞 Embedding API（一般保持默认即可）──
XFYUN_EMBEDDING_HOST=emb-cn-huabei-1.xf-yun.com
XFYUN_EMBEDDING_PATH=/v1/embeddings
XFYUN_EMBEDDING_MODEL=paraformer-zh

# ── 数据库 ──
# SQLite 示例（开发环境）
DATABASE_URL=sqlite:///./aptadapt.db

# ── JWT 配置 ──
# 生产环境请使用强随机字符串，长度建议 ≥32
JWT_SECRET_KEY=your-strong-random-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── 开发调试开关 ──
# 设为 1 时，Embedding 使用本地 Mock，不调用讯飞 Embedding API（省额度）
USE_MOCK_EMBEDDING=0
